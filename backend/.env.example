APP_NAME=Agent Eval Platform
APP_ENV=development
DATABASE_URL=sqlite:///./agent_eval.db
SQL_ECHO=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+|172\.(1[6-9]|2\d|3[01])\.\d+\.\d+)(:\d+)?
MODEL_ADAPTER_CONFIG=../config/model_adapters.json
PRICING_CONFIG=../config/pricing.json
DEFAULT_LLM_PROVIDER=bailian
DEEPSEEK_API_KEY=your-deepseek-api-key
BAILIAN_API_KEY=your-bailian-api-key
SEARCH_PROVIDER=bailian_builtin
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key
